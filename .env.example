# Fixflow Web – Environment Variables
# Copy to .env.local and fill in your values

# ── API ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8000

# ── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME=Fixflow

# ── Dev fallbacks (used when Clerk org/company not yet configured) ────────────
NEXT_PUBLIC_DEFAULT_TENANT_ID=test_tenant
NEXT_PUBLIC_DEFAULT_COMPANY_ID=06c6babe-24db-4f4d-9057-1c95acd06aaa

# ── Clerk ─────────────────────────────────────────────────────────────────────
# Get these from https://dashboard.clerk.com → Your App → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_REPLACE_ME
CLERK_SECRET_KEY=sk_test_REPLACE_ME

# ── Clerk redirect paths ──────────────────────────────────────────────────────
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/app/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/app/dashboard

# ── Connector downloads (optional — link to your actual release assets) ───────
NEXT_PUBLIC_CONNECTOR_WIN_URL=https://releases.fixflow.io/connector/latest/Fixflow-Connector-Setup.exe
NEXT_PUBLIC_CONNECTOR_MAC_URL=https://releases.fixflow.io/connector/latest/Fixflow-Connector.dmg
